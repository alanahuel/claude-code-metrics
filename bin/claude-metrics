#!/usr/bin/python3
"""claude-metrics — histórico de uso y gasto real de Claude Code en SQLite.

Complementa a `claude-usage` (que solo muestra el % de la ventana ACTUAL, sin
memoria). Aquí persistimos el histórico en una base local para poder consultar
gastos pasados con granularidad de HORA, y estimar el "gasto real" en dólares
como si pagaras por token a precio de API.

Dos fuentes de datos, con naturalezas distintas:

  · TOKENS + COSTE  ── reconstruibles con exactitud desde los transcripts
    locales (~/.claude/projects/*.jsonl). Cada `ingest` re-escanea todo y
    reconstruye la tabla horaria: idempotente, soporta cambios de precio y
    deduplica mensajes repetidos por sesiones reanudadas/compactadas. Backfillea
    automáticamente TODO el histórico que tengas en disco.

  · % DE USO (OAuth) ── valor instantáneo de ventana deslizante (5h/7d). NO se
    puede reconstruir hacia atrás, así que `snapshot` lo captura HACIA DELANTE y
    lo guarda con marca de tiempo. Llámalo periódicamente (timer) para tener la
    curva de % a lo largo del día.

Base de datos:  ~/.local/share/claude-metrics/metrics.db   (SQLite, 100% local)

Subcomandos:
  ingest            Re-escanea transcripts y reconstruye el histórico de tokens/coste.
  snapshot          Captura el % de uso OAuth actual (5h/7d/opus|sonnet) en el histórico.
  today             Desglose por hora del día de HOY (tokens, coste, modelos).
  day  [YYYY-MM-DD] Igual que `today` para una fecha concreta.
  week              Resumen de los últimos 7 días (coste y tokens por día).
  range A B         Resumen diario entre dos fechas (YYYY-MM-DD inclusive).
  util  [N]         Últimos N snapshots de % de uso (def. 24).
  models [N]        Gasto por modelo en los últimos N días (def. 30).
  projects [N]      Gasto por proyecto/carpeta en los últimos N días (def. 30).
  months            Comparativa de gasto mes a mes (todo el histórico).
  yield             Recalcula y estampa el ratio %/100k por modelo (NNLS) de hoy.
  total             Gasto y tokens acumulados de todo el histórico.
  dashboard         Genera el dashboard HTML con gráficas y lo abre en el navegador.
                    (`--no-open` solo lo regenera sin abrirlo).
  waybar            JSON para waybar: icono lanzador + tooltip con el resumen.
  db                Imprime la ruta de la base de datos.
"""

import glob
import json
import os
import sqlite3
import sys
from datetime import datetime, timezone, timedelta

HOME = os.path.expanduser("~")
LOG_DIR = os.path.join(HOME, ".claude", "projects")
DATA_DIR = os.path.join(HOME, ".local", "share", "claude-metrics")
DB_PATH = os.path.join(DATA_DIR, "metrics.db")
LIVE_CREDS = os.path.join(HOME, ".claude", ".credentials.json")
USAGE_URL = "https://api.anthropic.com/api/oauth/usage"

# --- Precios API por millón de tokens (USD) -------------------------------
# in / out base; los derivados de caché siguen la tarifa estándar de Anthropic:
#   cache write 5m = 1.25× input · cache write 1h = 2× input · cache read = 0.1× input
# Se calculan solos a partir de (input, output). Editar aquí y re-`ingest`
# recalcula TODO el histórico (el coste se recomputa en cada ingesta).
BASE_PRICES = {
    "claude-opus-4-8": (5.0, 25.0),
    "claude-opus-4-7": (5.0, 25.0),
    "claude-opus-4-6": (5.0, 25.0),
    "claude-opus-4-5": (5.0, 25.0),
    "claude-fable-5": (10.0, 50.0),
    "claude-sonnet-4-6": (3.0, 15.0),
    "claude-sonnet-4-5": (3.0, 15.0),
    "claude-haiku-4-5": (1.0, 5.0),
}


def price_for(model):
    """(in, out, cw5m, cw1h, cr) por millón para un modelo (admite sufijos
    de fecha y variantes [1m]). Devuelve None si no se reconoce el modelo."""
    if not model:
        return None
    m = model.lower().strip()
    # Normaliza: quita sufijos de fecha (-20251001) y marcadores como [1m].
    m = m.split("[")[0]
    base = None
    if m in BASE_PRICES:
        base = BASE_PRICES[m]
    else:
        for key, val in BASE_PRICES.items():
            if m.startswith(key):
                base = val
                break
    if base is None:
        return None
    pin, pout = base
    return (pin, pout, pin * 1.25, pin * 2.0, pin * 0.1)


# Raíces de espacio de trabajo que se "saltan" para llegar al nombre del
# proyecto (p. ej. ~/Documentos/programación/<proyecto>/... -> <proyecto>).
WORKSPACE_ROOTS = {"documentos", "programación", "programacion", "code",
                   "dev", "projects", "proyectos", "src", "repos", "git"}


def project_label(cwd):
    """Etiqueta de proyecto a partir del cwd del transcript. Agrupa subcarpetas
    bajo el directorio del proyecto; saltándose raíces de workspace conocidas."""
    if not cwd:
        return "(sin proyecto)"
    if cwd == HOME:
        return "~ (home)"
    rel = cwd[len(HOME) + 1:] if cwd.startswith(HOME + "/") else cwd.lstrip("/")
    parts = [p for p in rel.split("/") if p]
    while len(parts) > 1 and parts[0].lower() in WORKSPACE_ROOTS:
        parts.pop(0)
    return parts[0] if parts else (cwd or "(sin proyecto)")


# Mínimos para estimar el ratio por modelo (regresión sobre snapshots).
YIELD_MIN_UTIL = 2.0
YIELD_MIN_OBS = 6
YIELD_TRAILING_DAYS = 14


def nnls(X, y, iters=300):
    """Mínimos cuadrados no negativos por descenso por coordenadas.
    Resuelve  y ≈ X·β  con β ≥ 0. X: lista de filas, y: lista."""
    n = len(X)
    m = len(X[0]) if n else 0
    beta = [0.0] * m
    colsq = [sum(X[i][j] ** 2 for i in range(n)) or 1e-9 for j in range(m)]
    r = list(y)
    for _ in range(iters):
        for j in range(m):
            num = 0.0
            for i in range(n):
                r[i] += X[i][j] * beta[j]
                num += X[i][j] * r[i]
            bj = max(0.0, num / colsq[j])
            beta[j] = bj
            for i in range(n):
                r[i] -= X[i][j] * bj
    return beta


# --- SQLite -----------------------------------------------------------------
def connect():
    os.makedirs(DATA_DIR, exist_ok=True)
    con = sqlite3.connect(DB_PATH, timeout=10)
    con.execute("PRAGMA journal_mode=WAL")
    # Migración: si usage_hourly existe sin la columna 'project', se recrea
    # (los datos se reconstruyen con `ingest`, así que es seguro borrarla).
    try:
        cols = [r[1] for r in con.execute("PRAGMA table_info(usage_hourly)")]
        if cols and "project" not in cols:
            con.execute("DROP TABLE usage_hourly")
            con.commit()
    except sqlite3.Error:
        pass
    con.executescript(
        """
        CREATE TABLE IF NOT EXISTS usage_hourly (
            hour          TEXT NOT NULL,   -- 'YYYY-MM-DDTHH' en hora LOCAL
            project       TEXT NOT NULL,   -- proyecto/carpeta derivado del cwd
            model         TEXT NOT NULL,
            input         INTEGER NOT NULL DEFAULT 0,
            output        INTEGER NOT NULL DEFAULT 0,
            cache_write_5m INTEGER NOT NULL DEFAULT 0,
            cache_write_1h INTEGER NOT NULL DEFAULT 0,
            cache_read    INTEGER NOT NULL DEFAULT 0,
            messages      INTEGER NOT NULL DEFAULT 0,
            cost_usd      REAL NOT NULL DEFAULT 0,
            PRIMARY KEY (hour, project, model)
        );
        CREATE TABLE IF NOT EXISTS util_snapshots (
            ts          TEXT NOT NULL,    -- ISO UTC del momento de captura
            window      TEXT NOT NULL,    -- five_hour | seven_day | seven_day_opus | ...
            utilization REAL,
            resets_at   TEXT,
            PRIMARY KEY (ts, window)
        );
        -- Ratio %/100k por modelo, estampado por día (serie temporal). Se
        -- recalcula vía NNLS sobre una ventana móvil de snapshots.
        CREATE TABLE IF NOT EXISTS model_yield (
            day     TEXT NOT NULL,        -- 'YYYY-MM-DD' (hora local)
            window  TEXT NOT NULL,        -- five_hour | seven_day
            model   TEXT NOT NULL,
            beta    REAL NOT NULL,        -- % de ventana por 100k tokens
            r2      REAL,                 -- calidad del ajuste
            n_obs   INTEGER,
            PRIMARY KEY (day, window, model)
        );
        CREATE TABLE IF NOT EXISTS meta (
            key TEXT PRIMARY KEY,
            value TEXT
        );
        """
    )
    return con


# --- Ingesta de tokens (desde transcripts) ----------------------------------
def _parse_iso(s):
    if not s:
        return None
    try:
        return datetime.fromisoformat(s.replace("Z", "+00:00"))
    except (ValueError, AttributeError):
        return None


def ingest(con, verbose=True):
    """Re-escanea TODOS los transcripts y reconstruye usage_hourly por completo.

    Estrategia full-rescan + REPLACE atómico: idempotente, recoge cambios de
    precio y borrados, deduplica por (id de mensaje, requestId). ~1-2 s para
    decenas de MB; si algún día el histórico es enorme, se puede acotar.
    """
    buckets = {}   # (hour_local, model) -> dict de sumas
    seen = set()
    unknown_models = set()
    files = glob.glob(os.path.join(LOG_DIR, "*", "*.jsonl"))
    n_msgs = 0
    for path in files:
        try:
            fh = open(path, encoding="utf-8", errors="replace")
        except OSError:
            continue
        with fh:
            for line in fh:
                if '"usage"' not in line:
                    continue
                try:
                    o = json.loads(line)
                except ValueError:
                    continue
                msg = o.get("message") or {}
                u = msg.get("usage")
                if not isinstance(u, dict):
                    continue
                ts = _parse_iso(o.get("timestamp"))
                if ts is None:
                    continue
                model = msg.get("model") or "unknown"
                if model == "<synthetic>":
                    continue  # mensajes sintéticos: sin coste real
                project = project_label(o.get("cwd"))
                dkey = (msg.get("id"), o.get("requestId"))
                if dkey != (None, None):
                    if dkey in seen:
                        continue
                    seen.add(dkey)

                inp = u.get("input_tokens") or 0
                out = u.get("output_tokens") or 0
                cr = u.get("cache_read_input_tokens") or 0
                cc = u.get("cache_creation") or {}
                cw5m = cc.get("ephemeral_5m_input_tokens") or 0
                cw1h = cc.get("ephemeral_1h_input_tokens") or 0
                # Fallback: si no viene el desglose 5m/1h, todo a 5m.
                if not cw5m and not cw1h:
                    cw5m = u.get("cache_creation_input_tokens") or 0

                hour = ts.astimezone().strftime("%Y-%m-%dT%H")
                key = (hour, project, model)
                b = buckets.get(key)
                if b is None:
                    b = buckets[key] = {"in": 0, "out": 0, "cw5m": 0,
                                        "cw1h": 0, "cr": 0, "n": 0}
                b["in"] += inp
                b["out"] += out
                b["cw5m"] += cw5m
                b["cw1h"] += cw1h
                b["cr"] += cr
                b["n"] += 1
                n_msgs += 1

    rows = []
    for (hour, project, model), b in buckets.items():
        p = price_for(model)
        if p is None:
            unknown_models.add(model)
            cost = 0.0
        else:
            pin, pout, pcw5m, pcw1h, pcr = p
            cost = (b["in"] * pin + b["out"] * pout + b["cw5m"] * pcw5m
                    + b["cw1h"] * pcw1h + b["cr"] * pcr) / 1_000_000
        rows.append((hour, project, model, b["in"], b["out"], b["cw5m"],
                     b["cw1h"], b["cr"], b["n"], cost))

    with con:
        con.execute("DELETE FROM usage_hourly")
        con.executemany(
            "INSERT INTO usage_hourly (hour, project, model, input, output, "
            "cache_write_5m, cache_write_1h, cache_read, messages, cost_usd) "
            "VALUES (?,?,?,?,?,?,?,?,?,?)", rows)
        con.execute("INSERT OR REPLACE INTO meta (key, value) VALUES "
                    "('last_ingest', ?)",
                    (datetime.now(timezone.utc).isoformat(),))

    # Mantén el export JSON fresco para el dashboard web (Astro).
    try:
        export_json(con)
    except Exception:  # noqa: BLE001
        pass

    if verbose:
        total = sum(r[9] for r in rows)
        print(f"Ingeridos {n_msgs} mensajes en {len(rows)} celdas (hora×modelo) "
              f"de {len(files)} ficheros.")
        print(f"Gasto total estimado del histórico: ${total:,.2f}")
        if unknown_models:
            print("Modelos sin precio (coste=0): "
                  + ", ".join(sorted(unknown_models)), file=sys.stderr)


# --- Export JSON (capa de datos para el dashboard web) ----------------------
EXPORT_PATH = os.path.join(DATA_DIR, "metrics.json")
# Orden de columnas de cada fila horaria (formato compacto para el cliente).
HOURLY_COLS = ["hour", "project", "model", "input", "output", "cache_write_5m",
               "cache_write_1h", "cache_read", "messages", "cost_usd"]


def export_json(con):
    """Vuelca TODO el detalle horario + snapshots de % a JSON, para que el
    dashboard agregue/filtre con precisión en el cliente. Fichero pequeño
    (una fila por hora×modelo)."""
    hourly = con.execute(
        "SELECT hour, project, model, input, output, cache_write_5m, "
        "cache_write_1h, cache_read, messages, cost_usd FROM usage_hourly "
        "ORDER BY hour").fetchall()
    util = con.execute(
        "SELECT ts, window, utilization, resets_at FROM util_snapshots "
        "ORDER BY ts").fetchall()
    last_ingest_row = con.execute(
        "SELECT value FROM meta WHERE key='last_ingest'").fetchone()
    pricing = {m: list(BASE_PRICES[m]) for m in BASE_PRICES}
    now = datetime.now().astimezone()
    data = {
        "generated_at": now.isoformat(),
        "tz": str(now.tzinfo),
        "tz_offset_minutes": int(now.utcoffset().total_seconds() // 60),
        "last_ingest": last_ingest_row[0] if last_ingest_row else None,
        "hourly_cols": HOURLY_COLS,
        "hourly": [list(r) for r in hourly],
        "util": [list(r) for r in util],
        "pricing": pricing,
    }
    my = con.execute(
        "SELECT day, window, model, beta, r2, n_obs FROM model_yield "
        "ORDER BY day").fetchall()
    data["model_yield"] = [list(r) for r in my]
    os.makedirs(DATA_DIR, exist_ok=True)
    tmp = EXPORT_PATH + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(data, f, separators=(",", ":"))
    os.replace(tmp, EXPORT_PATH)
    return EXPORT_PATH


def compute_model_yield(con, window="five_hour", verbose=False):
    """Estima el ratio %/100k por modelo (NNLS) sobre los snapshots de la
    ventana móvil reciente y lo estampa con la fecha de HOY. Idempotente por
    día (INSERT OR REPLACE), así que a lo largo del día se refina y queda
    congelado al pasar al siguiente."""
    win_secs = 7 * 86400 if window == "seven_day" else 5 * 3600
    now = datetime.now().astimezone()
    cutoff = now.timestamp() - YIELD_TRAILING_DAYS * 86400
    snaps = [(ts, u) for ts, u in con.execute(
        "SELECT ts, utilization FROM util_snapshots WHERE window=? "
        "AND utilization >= ? ORDER BY ts", (window, YIELD_MIN_UTIL))
        if _parse_iso(ts) and _parse_iso(ts).timestamp() >= cutoff]
    if len(snaps) < YIELD_MIN_OBS:
        if verbose:
            print(f"Snapshots insuficientes ({len(snaps)}/{YIELD_MIN_OBS}) "
                  f"para el ratio por modelo de {window}.")
        return 0

    # Tokens por (hora local, modelo) -> sumas en la ventana móvil de cada snapshot.
    bdict = {}
    for hour, model, tk in con.execute(
            "SELECT hour, model, input+output+cache_write_5m+cache_write_1h"
            "+cache_read FROM usage_hourly"):
        try:
            sec = datetime.fromisoformat(hour + ":00:00").timestamp()
        except ValueError:
            continue
        d = bdict.setdefault(sec, {})
        d[model] = d.get(model, 0) + (tk or 0)
    secs = sorted(bdict)

    obs = []
    for ts, u in snaps:
        end = _parse_iso(ts).timestamp()
        lo = end - win_secs - 3600
        acc = {}
        for s in secs:
            if lo < s <= end:
                for m, t in bdict[s].items():
                    acc[m] = acc.get(m, 0) + t
        if acc:
            obs.append((u, acc))
    if len(obs) < YIELD_MIN_OBS:
        return 0

    mtot = {}
    for u, acc in obs:
        for m, t in acc.items():
            mtot[m] = mtot.get(m, 0) + t
    models = sorted(mtot, key=lambda m: -mtot[m])
    X = [[acc.get(m, 0) / 1e5 for m in models] for _, acc in obs]
    y = [u for u, _ in obs]
    beta = nnls(X, y)

    ybar = sum(y) / len(y)
    ssr = sst = 0.0
    for i, (_, _acc) in enumerate(obs):
        fit = sum(X[i][j] * beta[j] for j in range(len(models)))
        ssr += (y[i] - fit) ** 2
        sst += (y[i] - ybar) ** 2
    r2 = max(0.0, 1 - ssr / sst) if sst > 0 else 0.0

    day = now.strftime("%Y-%m-%d")
    with con:
        for j, m in enumerate(models):
            con.execute(
                "INSERT OR REPLACE INTO model_yield "
                "(day, window, model, beta, r2, n_obs) VALUES (?,?,?,?,?,?)",
                (day, window, m, beta[j], r2, len(obs)))
    if verbose:
        print(f"Ratio %/100k por modelo — {day} · {window} · "
              f"n={len(obs)} · R²={r2:.2f}")
        for j, m in enumerate(models):
            print(f"  {m.replace('claude-',''):<16} {beta[j]:>5.2f}%/100k")
    return len(obs)


# --- Snapshot del % de uso (OAuth) ------------------------------------------
def snapshot(con, verbose=True):
    """Captura el % de uso actual de la API OAuth y lo guarda con timestamp.

    Forward-only: este dato no es reconstruible, así que conviene llamarlo
    periódicamente (timer) para tener la curva del día."""
    import ssl
    import urllib.request

    try:
        creds = json.load(open(LIVE_CREDS))["claudeAiOauth"]
        token = creds["accessToken"]
    except (OSError, KeyError, ValueError) as e:
        if verbose:
            print(f"No se pudo leer el token OAuth: {e}", file=sys.stderr)
        return 1

    req = urllib.request.Request(USAGE_URL, headers={
        "Accept": "application/json",
        "Authorization": "Bearer " + token,
        "anthropic-beta": "oauth-2025-04-20",
    })
    try:
        with urllib.request.urlopen(req, timeout=10,
                                    context=ssl.create_default_context()) as r:
            usage = json.loads(r.read().decode())
    except Exception as e:  # noqa: BLE001
        if verbose:
            print(f"Error consultando la API de uso: {e}", file=sys.stderr)
        return 1

    ts = datetime.now(timezone.utc).isoformat()
    rows = []
    for key in ("five_hour", "seven_day", "seven_day_opus", "seven_day_sonnet"):
        w = usage.get(key)
        if isinstance(w, dict) and w.get("utilization") is not None:
            rows.append((ts, key, float(w["utilization"]), w.get("resets_at")))
    if not rows:
        if verbose:
            print("La API no devolvió ventanas de uso.", file=sys.stderr)
        return 1
    with con:
        con.executemany("INSERT OR REPLACE INTO util_snapshots "
                        "(ts, window, utilization, resets_at) VALUES (?,?,?,?)",
                        rows)
    # Refresca el ratio por modelo del día con la nueva muestra.
    for win in ("five_hour", "seven_day"):
        try:
            compute_model_yield(con, window=win)
        except Exception:  # noqa: BLE001
            pass
    # Deja el export JSON al día (el dashboard lo lee directamente).
    try:
        export_json(con)
    except Exception:  # noqa: BLE001
        pass
    if verbose:
        parts = [f"{k}={v:.0f}%" for _, k, v, _ in rows]
        print("Snapshot guardado: " + " · ".join(parts))
    return 0


# --- Formato -----------------------------------------------------------------
def fmt_tok(n):
    n = int(n)
    if n >= 1_000_000_000:
        return f"{n/1e9:.1f}G"
    if n >= 1_000_000:
        return f"{n/1e6:.1f}M"
    if n >= 1_000:
        return f"{n/1e3:.1f}k"
    return str(n)


def bar(frac, width=20):
    frac = max(0.0, min(1.0, frac))
    filled = int(round(frac * width))
    return "█" * filled + "░" * (width - filled)


# --- Informes ----------------------------------------------------------------
def report_day(con, date_str):
    cur = con.execute(
        "SELECT hour, model, input, output, cache_write_5m, cache_write_1h, "
        "cache_read, messages, cost_usd FROM usage_hourly "
        "WHERE hour LIKE ? ORDER BY hour", (date_str + "T%",))
    rows = cur.fetchall()
    if not rows:
        print(f"Sin datos para {date_str}.  (¿has corrido `claude-metrics ingest`?)")
        return
    # Agrega por hora.
    by_hour = {}
    by_model = {}
    total_cost = 0.0
    total_tok = 0
    for (hour, model, inp, out, cw5m, cw1h, cr, n, cost) in rows:
        h = hour[-2:]
        d = by_hour.setdefault(h, {"cost": 0.0, "tok": 0, "n": 0})
        tok = inp + out + cw5m + cw1h + cr
        d["cost"] += cost
        d["tok"] += tok
        d["n"] += n
        by_model[model] = by_model.get(model, 0.0) + cost
        total_cost += cost
        total_tok += tok

    peak = max((d["cost"] for d in by_hour.values()), default=0.0) or 1.0
    print(f"  Gasto por hora — {date_str}   (hora local)")
    print(f"  {'─'*54}")
    for h in sorted(by_hour):
        d = by_hour[h]
        print(f"  {h}:00  {bar(d['cost']/peak)}  ${d['cost']:>7.3f}   "
              f"{fmt_tok(d['tok']):>6} tok · {d['n']} msg")
    print(f"  {'─'*54}")
    models_s = " · ".join(f"{m.replace('claude-','')}: ${c:.2f}"
                          for m, c in sorted(by_model.items(),
                                             key=lambda x: -x[1]))
    print(f"  Modelos:  {models_s}")
    print(f"  TOTAL:    ${total_cost:.2f}   ({fmt_tok(total_tok)} tokens)")


def report_range(con, start, end):
    cur = con.execute(
        "SELECT substr(hour,1,10) AS day, SUM(cost_usd), "
        "SUM(input+output+cache_write_5m+cache_write_1h+cache_read), "
        "SUM(messages) FROM usage_hourly "
        "WHERE day BETWEEN ? AND ? GROUP BY day ORDER BY day", (start, end))
    rows = cur.fetchall()
    if not rows:
        print(f"Sin datos entre {start} y {end}.")
        return
    peak = max((r[1] for r in rows), default=0.0) or 1.0
    tc = tt = tm = 0.0
    print(f"  Gasto diario — {start} → {end}")
    print(f"  {'─'*56}")
    for (day, cost, tok, msg) in rows:
        print(f"  {day}  {bar(cost/peak)}  ${cost:>7.2f}   "
              f"{fmt_tok(tok):>6} tok · {int(msg)} msg")
        tc += cost
        tt += tok
        tm += msg
    print(f"  {'─'*56}")
    print(f"  TOTAL:  ${tc:.2f}   {fmt_tok(tt)} tokens · {int(tm)} mensajes")
    print(f"  Media/día: ${tc/len(rows):.2f}")


def report_models(con, days):
    since = (datetime.now().astimezone() - timedelta(days=days)).strftime("%Y-%m-%d")
    cur = con.execute(
        "SELECT model, SUM(cost_usd), SUM(input), SUM(output), "
        "SUM(cache_write_5m+cache_write_1h), SUM(cache_read), SUM(messages) "
        "FROM usage_hourly WHERE substr(hour,1,10) >= ? "
        "GROUP BY model ORDER BY SUM(cost_usd) DESC", (since,))
    rows = cur.fetchall()
    if not rows:
        print(f"Sin datos en los últimos {days} días.")
        return
    total = sum(r[1] for r in rows) or 1.0
    print(f"  Gasto por modelo — últimos {days} días")
    print(f"  {'─'*60}")
    for (model, cost, inp, out, cw, cr, msg) in rows:
        m = model.replace("claude-", "")
        print(f"  {m:<16} ${cost:>7.2f}  ({cost/total*100:>4.1f}%)   "
              f"in {fmt_tok(inp)} · out {fmt_tok(out)} · "
              f"cw {fmt_tok(cw)} · cr {fmt_tok(cr)}")
    print(f"  {'─'*60}")
    print(f"  TOTAL:  ${total:.2f}")


def report_projects(con, days):
    since = (datetime.now().astimezone() - timedelta(days=days)).strftime("%Y-%m-%d")
    rows = con.execute(
        "SELECT project, SUM(cost_usd), "
        "SUM(input+output+cache_write_5m+cache_write_1h+cache_read), "
        "SUM(messages) FROM usage_hourly WHERE substr(hour,1,10) >= ? "
        "GROUP BY project ORDER BY SUM(cost_usd) DESC", (since,)).fetchall()
    if not rows:
        print(f"Sin datos en los últimos {days} días.")
        return
    total = sum(r[1] for r in rows) or 1.0
    print(f"  Gasto por proyecto — últimos {days} días")
    print(f"  {'─'*58}")
    for (proj, cost, tok, msg) in rows:
        print(f"  {proj[:22]:<22} {bar(cost/total, 12)} ${cost:>7.2f}  "
              f"({cost/total*100:>4.1f}%)  {fmt_tok(tok):>6} tok")
    print(f"  {'─'*58}")
    print(f"  TOTAL:  ${total:.2f}  ·  {len(rows)} proyectos")


def report_months(con):
    rows = con.execute(
        "SELECT substr(hour,1,7) AS m, SUM(cost_usd), "
        "SUM(input+output+cache_write_5m+cache_write_1h+cache_read), "
        "SUM(messages) FROM usage_hourly GROUP BY m ORDER BY m").fetchall()
    if not rows:
        print("Sin datos.")
        return
    peak = max((r[1] for r in rows), default=0.0) or 1.0
    print("  Comparativa mensual")
    print(f"  {'─'*56}")
    prev = None
    for (m, cost, tok, msg) in rows:
        delta = ""
        if prev is not None and prev > 0:
            d = (cost - prev) / prev * 100
            delta = f"  {'▲' if d>=0 else '▼'}{abs(d):>4.0f}%"
        print(f"  {m}  {bar(cost/peak, 16)} ${cost:>8.2f}  "
              f"{fmt_tok(tok):>6} tok{delta}")
        prev = cost
    print(f"  {'─'*56}")
    print(f"  TOTAL:  ${sum(r[1] for r in rows):.2f}  ·  {len(rows)} meses")


def report_total(con):
    r = con.execute(
        "SELECT SUM(cost_usd), SUM(input), SUM(output), "
        "SUM(cache_write_5m+cache_write_1h), SUM(cache_read), SUM(messages), "
        "MIN(hour), MAX(hour) FROM usage_hourly").fetchone()
    if not r or r[0] is None:
        print("Sin datos. Corre `claude-metrics ingest`.")
        return
    cost, inp, out, cw, cr, msg, hmin, hmax = r
    print(f"  Histórico completo  ({hmin} → {hmax}, hora local)")
    print(f"  {'─'*48}")
    print(f"  Gasto real estimado : ${cost:,.2f}")
    print(f"  Mensajes            : {int(msg):,}")
    print(f"  Input               : {fmt_tok(inp)}")
    print(f"  Output              : {fmt_tok(out)}")
    print(f"  Cache write         : {fmt_tok(cw)}")
    print(f"  Cache read          : {fmt_tok(cr)}")
    print(f"  Total tokens        : {fmt_tok(inp+out+cw+cr)}")


def report_util(con, n):
    cur = con.execute(
        "SELECT ts, window, utilization FROM util_snapshots "
        "ORDER BY ts DESC LIMIT ?", (n * 4,))
    rows = cur.fetchall()
    if not rows:
        print("Sin snapshots de % de uso. Corre `claude-metrics snapshot` "
              "(o programa el timer).")
        return
    # Agrupa por timestamp.
    by_ts = {}
    for ts, win, util in rows:
        by_ts.setdefault(ts, {})[win] = util
    order = ["five_hour", "seven_day", "seven_day_opus", "seven_day_sonnet"]
    lbl = {"five_hour": "5h", "seven_day": "7d",
           "seven_day_opus": "op", "seven_day_sonnet": "so"}
    print(f"  % de uso — últimos {n} snapshots (hora local)")
    print(f"  {'─'*46}")
    for ts in sorted(by_ts)[-n:]:
        local = _parse_iso(ts).astimezone().strftime("%d %b %H:%M")
        parts = [f"{lbl[w]} {by_ts[ts][w]:>3.0f}%" for w in order
                 if w in by_ts[ts]]
        print(f"  {local}   " + " · ".join(parts))


# --- Dashboard HTML (gráficas SVG autocontenidas, sin internet) -------------
# Paleta gruvbox para encajar con el resto del escritorio.
PALETTE = ["#98971a", "#d79921", "#d65d0e", "#458588", "#b16286",
           "#689d6a", "#cc241d", "#a89984"]
GB = {"bg": "#1d2021", "panel": "#282828", "panel2": "#32302f",
      "fg": "#ebdbb2", "muted": "#928374", "grid": "#3c3836",
      "green": "#98971a", "yellow": "#d79921", "orange": "#d65d0e",
      "red": "#cc241d", "blue": "#458588", "aqua": "#689d6a"}


def _esc(s):
    return (str(s).replace("&", "&amp;").replace("<", "&lt;")
            .replace(">", "&gt;").replace('"', "&quot;"))


def _vbars(data, unit="$", color=GB["yellow"], height=180):
    """Gráfica de barras verticales. data = [(label, value), ...]."""
    if not data:
        return "<p class='empty'>sin datos</p>"
    w, h = 760, height
    pad_b, pad_l = 28, 8
    n = len(data)
    gap = 3
    bw = max(2, (w - pad_l) / n - gap)
    mx = max((v for _, v in data), default=0) or 1.0
    plot_h = h - pad_b - 10
    out = [f"<svg viewBox='0 0 {w} {h}' class='chart' "
           f"preserveAspectRatio='none'>"]
    for i, (lbl, v) in enumerate(data):
        bh = (v / mx) * plot_h
        x = pad_l + i * (bw + gap)
        y = 10 + plot_h - bh
        title = f"{lbl}: {unit}{v:,.2f}" if unit == "$" else f"{lbl}: {v}"
        out.append(
            f"<rect x='{x:.1f}' y='{y:.1f}' width='{bw:.1f}' height='{bh:.1f}' "
            f"rx='1.5' fill='{color}'><title>{_esc(title)}</title></rect>")
        # Etiqueta del eje X (1 de cada ~tantas para no saturar).
        step = max(1, n // 16)
        if i % step == 0:
            out.append(
                f"<text x='{x + bw/2:.1f}' y='{h-9}' fill='{GB['muted']}' "
                f"font-size='10' text-anchor='middle'>{_esc(lbl)}</text>")
    out.append("</svg>")
    return "".join(out)


def _hbars(data, unit="$"):
    """Barras horizontales con etiqueta + valor. data=[(label,value,color)]."""
    if not data:
        return "<p class='empty'>sin datos</p>"
    mx = max((v for _, v, _ in data), default=0) or 1.0
    rows = []
    for (lbl, v, col) in data:
        pct = v / mx * 100
        val = f"${v:,.2f}" if unit == "$" else f"{v}"
        rows.append(
            f"<div class='hbar-row'><span class='hbar-lbl'>{_esc(lbl)}</span>"
            f"<span class='hbar-track'><span class='hbar-fill' "
            f"style='width:{pct:.1f}%;background:{col}'></span></span>"
            f"<span class='hbar-val'>{val}</span></div>")
    return "".join(rows)


def _line(series, height=170, ymax=100, unit="%"):
    """Gráfica de líneas. series = [(nombre, color, [(x_iso, y), ...]), ...].
    El eje X se reparte uniforme por índice (los snapshots son ~regulares)."""
    pts_any = any(s[2] for s in series)
    if not pts_any:
        return "<p class='empty'>sin snapshots todavía — el timer los irá " \
               "capturando</p>"
    w, h = 760, height
    pad_b = 24
    plot_h = h - pad_b - 8
    n = max((len(s[2]) for s in series), default=1)
    out = [f"<svg viewBox='0 0 {w} {h}' class='chart' "
           f"preserveAspectRatio='none'>"]
    # Líneas de referencia horizontales (25/50/75/100%).
    for gy in (0, 25, 50, 75, 100):
        y = 8 + plot_h - (gy / ymax) * plot_h
        out.append(f"<line x1='0' y1='{y:.1f}' x2='{w}' y2='{y:.1f}' "
                   f"stroke='{GB['grid']}' stroke-width='1'/>")
        out.append(f"<text x='2' y='{y-2:.1f}' fill='{GB['muted']}' "
                   f"font-size='9'>{gy}{unit}</text>")
    for (name, col, pts) in series:
        if not pts:
            continue
        coords = []
        for i, (_, yv) in enumerate(pts):
            x = (i / max(1, n - 1)) * w
            y = 8 + plot_h - (min(yv, ymax) / ymax) * plot_h
            coords.append(f"{x:.1f},{y:.1f}")
        out.append(f"<polyline points='{' '.join(coords)}' fill='none' "
                   f"stroke='{col}' stroke-width='2' "
                   f"stroke-linejoin='round'/>")
    out.append("</svg>")
    return "".join(out)


def build_dashboard_html(con):
    now = datetime.now().astimezone()
    today = now.strftime("%Y-%m-%d")
    month = now.strftime("%Y-%m")

    # KPIs.
    def scalar(q, p=()):
        r = con.execute(q, p).fetchone()
        return (r[0] or 0) if r and r[0] is not None else 0
    cost_today = scalar("SELECT SUM(cost_usd) FROM usage_hourly WHERE hour LIKE ?",
                        (today + "T%",))
    cost_month = scalar("SELECT SUM(cost_usd) FROM usage_hourly WHERE hour LIKE ?",
                        (month + "-%",))
    cost_total = scalar("SELECT SUM(cost_usd) FROM usage_hourly")
    msg_total = scalar("SELECT SUM(messages) FROM usage_hourly")
    tok_total = scalar("SELECT SUM(input+output+cache_write_5m+cache_write_1h"
                       "+cache_read) FROM usage_hourly")

    # Gasto por hora hoy (24 barras).
    hourly = {f"{h:02d}": 0.0 for h in range(24)}
    for (hh, c) in con.execute(
            "SELECT substr(hour,12,2), SUM(cost_usd) FROM usage_hourly "
            "WHERE hour LIKE ? GROUP BY substr(hour,12,2)", (today + "T%",)):
        hourly[hh] = c or 0.0
    hourly_data = [(h, hourly[h]) for h in sorted(hourly)]

    # Gasto diario últimos 30 días.
    since30 = (now - timedelta(days=29)).strftime("%Y-%m-%d")
    daily_raw = dict(con.execute(
        "SELECT substr(hour,1,10), SUM(cost_usd) FROM usage_hourly "
        "WHERE substr(hour,1,10) >= ? GROUP BY substr(hour,1,10)", (since30,)))
    daily_data = []
    for i in range(30):
        d = (now - timedelta(days=29 - i)).strftime("%Y-%m-%d")
        daily_data.append((d[5:], daily_raw.get(d, 0.0)))

    # Por modelo (30 días).
    model_rows = con.execute(
        "SELECT model, SUM(cost_usd) FROM usage_hourly "
        "WHERE substr(hour,1,10) >= ? GROUP BY model ORDER BY SUM(cost_usd) DESC",
        (since30,)).fetchall()
    model_data = [(m.replace("claude-", ""), c or 0.0,
                   PALETTE[i % len(PALETTE)])
                  for i, (m, c) in enumerate(model_rows)]

    # % de uso: últimos 7 días de snapshots, líneas 5h y 7d.
    since7 = (now - timedelta(days=7)).astimezone(timezone.utc).isoformat()
    util_rows = con.execute(
        "SELECT ts, window, utilization FROM util_snapshots WHERE ts >= ? "
        "ORDER BY ts", (since7,)).fetchall()
    s5, s7 = [], []
    for (ts, win, u) in util_rows:
        if win == "five_hour":
            s5.append((ts, u or 0))
        elif win == "seven_day":
            s7.append((ts, u or 0))
    util_series = [("5h", GB["orange"], s5), ("7d (semanal)", GB["blue"], s7)]

    # --- Render -------------------------------------------------------------
    def fmt_money(x):
        return f"${x:,.2f}"
    cards = [
        ("Hoy", fmt_money(cost_today), GB["green"]),
        ("Este mes", fmt_money(cost_month), GB["yellow"]),
        ("Histórico", fmt_money(cost_total), GB["orange"]),
        ("Mensajes", f"{int(msg_total):,}", GB["blue"]),
        ("Tokens", fmt_tok(tok_total), GB["aqua"]),
    ]
    cards_html = "".join(
        f"<div class='card'><div class='card-v' style='color:{col}'>{v}</div>"
        f"<div class='card-l'>{_esc(l)}</div></div>" for (l, v, col) in cards)

    model_legend = "".join(
        f"<span class='leg'><i style='background:{c}'></i>{_esc(m)} "
        f"${v:,.2f}</span>" for (m, v, c) in model_data)

    html = f"""<!DOCTYPE html>
<html lang="es"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta http-equiv="refresh" content="120">
<title>Claude · Métricas de gasto</title>
<style>
  :root {{ color-scheme: dark; }}
  * {{ box-sizing: border-box; }}
  body {{ margin:0; background:{GB['bg']}; color:{GB['fg']};
    font-family: 'JetBrains Mono','DejaVu Sans Mono',ui-monospace,monospace;
    padding: 28px clamp(16px,4vw,56px); }}
  h1 {{ font-size:20px; font-weight:600; margin:0 0 2px; letter-spacing:.3px; }}
  .sub {{ color:{GB['muted']}; font-size:12px; margin-bottom:24px; }}
  .cards {{ display:grid; gap:12px; margin-bottom:28px;
    grid-template-columns: repeat(auto-fit,minmax(140px,1fr)); }}
  .card {{ background:{GB['panel']}; border:1px solid {GB['grid']};
    border-radius:10px; padding:16px 18px; }}
  .card-v {{ font-size:26px; font-weight:700; }}
  .card-l {{ color:{GB['muted']}; font-size:12px; margin-top:4px; }}
  .panel {{ background:{GB['panel']}; border:1px solid {GB['grid']};
    border-radius:12px; padding:18px 20px 14px; margin-bottom:22px; }}
  .panel h2 {{ font-size:13px; font-weight:600; margin:0 0 14px;
    color:{GB['fg']}; text-transform:uppercase; letter-spacing:1px; }}
  .panel h2 span {{ color:{GB['muted']}; text-transform:none;
    font-weight:400; letter-spacing:0; }}
  .chart {{ width:100%; height:auto; display:block; }}
  .empty {{ color:{GB['muted']}; font-size:13px; padding:18px 0; }}
  .hbar-row {{ display:flex; align-items:center; gap:12px; margin:8px 0;
    font-size:13px; }}
  .hbar-lbl {{ width:120px; flex:none; }}
  .hbar-track {{ flex:1; height:14px; background:{GB['panel2']};
    border-radius:7px; overflow:hidden; }}
  .hbar-fill {{ display:block; height:100%; border-radius:7px; }}
  .hbar-val {{ width:84px; flex:none; text-align:right;
    color:{GB['muted']}; }}
  .legend {{ margin-top:12px; display:flex; flex-wrap:wrap; gap:14px;
    font-size:12px; color:{GB['muted']}; }}
  .leg i {{ display:inline-block; width:10px; height:10px; border-radius:3px;
    margin-right:6px; vertical-align:-1px; }}
  footer {{ color:{GB['muted']}; font-size:11px; margin-top:8px; }}
  footer code {{ color:{GB['fg']}; }}
</style></head>
<body>
  <h1>󰧑 Claude Code · gasto real (equivalente API)</h1>
  <div class="sub">Actualizado {now.strftime('%d %b %Y · %H:%M')} ·
    se auto-refresca cada 2 min · datos locales (SQLite)</div>

  <div class="cards">{cards_html}</div>

  <div class="panel"><h2>Gasto por hora · hoy <span>({today})</span></h2>
    {_vbars(hourly_data, color=GB['yellow'])}</div>

  <div class="panel"><h2>Gasto diario · últimos 30 días</h2>
    {_vbars(daily_data, color=GB['orange'])}</div>

  <div class="panel"><h2>Gasto por modelo <span>· últimos 30 días</span></h2>
    {_hbars(model_data)}
    <div class="legend">{model_legend}</div></div>

  <div class="panel"><h2>% de uso de las ventanas <span>· últimos 7 días</span></h2>
    {_line(util_series)}
    <div class="legend">
      <span class="leg"><i style="background:{GB['orange']}"></i>ventana 5h</span>
      <span class="leg"><i style="background:{GB['blue']}"></i>ventana semanal (7d)</span>
    </div></div>

  <footer>Generado por <code>claude-metrics dashboard</code> ·
    el % de uso se captura hacia delante (timer cada 15 min);
    tokens y coste se reconstruyen de los transcripts.</footer>
</body></html>"""
    return html


def dashboard(con, open_browser=True):
    _ingest_if_stale(con)
    html = build_dashboard_html(con)
    path = os.path.join(DATA_DIR, "dashboard.html")
    with open(path, "w", encoding="utf-8") as f:
        f.write(html)
    if open_browser:
        _open_path(path)
    print(path)


def _open_path(path):
    """Abre un archivo/URL con el navegador o app por defecto del SO."""
    import subprocess
    try:
        if sys.platform == "darwin":  # macOS
            subprocess.Popen(["open", path])
        elif sys.platform.startswith("win"):  # Windows
            os.startfile(path)  # type: ignore[attr-defined]  # noqa: B606 (solo Win)
        else:  # Linux / *BSD
            subprocess.Popen(["xdg-open", path],
                             stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except (OSError, AttributeError, subprocess.SubprocessError):
        pass


def _ingest_if_stale(con, max_age_secs=600):
    """Reconstruye el histórico si la última ingesta es vieja. Hace que el
    módulo de waybar funcione solo, sin depender del timer de systemd."""
    try:
        row = con.execute("SELECT value FROM meta WHERE key='last_ingest'").fetchone()
        last = _parse_iso(row[0]) if row else None
        age = (datetime.now(timezone.utc) - last).total_seconds() if last else 1e9
        if age >= max_age_secs:
            ingest(con, verbose=False)
    except Exception:  # noqa: BLE001  (un fallo de ingesta no debe tumbar la barra)
        pass


def waybar(con):
    """Salida solo-icono para waybar (sin precio en la barra). El desglose
    vive en el tooltip al pasar el ratón; un clic abre el dashboard."""
    _ingest_if_stale(con)
    now = datetime.now().astimezone()
    today = now.strftime("%Y-%m-%d")
    month = now.strftime("%Y-%m")
    r = con.execute(
        "SELECT SUM(cost_usd), SUM(input+output+cache_write_5m+"
        "cache_write_1h+cache_read) FROM usage_hourly WHERE hour LIKE ?",
        (today + "T%",)).fetchone()
    cost = (r[0] or 0.0) if r else 0.0
    tok = (r[1] or 0) if r else 0
    rm = con.execute("SELECT SUM(cost_usd) FROM usage_hourly WHERE hour LIKE ?",
                     (month + "-%",)).fetchone()
    month_cost = (rm[0] or 0.0) if rm else 0.0
    text = "\U000f0a99"  # 󰪙 chart-box: lanzador del dashboard
    tooltip = (f"<b>Métricas de Claude</b>  <i>(clic = dashboard)</i>\n"
               f"Hoy:   ${cost:.2f}   ({fmt_tok(tok)} tok)\n"
               f"Mes:   ${month_cost:.2f}")
    print(json.dumps({"text": text, "tooltip": tooltip, "class": "claude-metrics"}))


# --- main --------------------------------------------------------------------
def main():
    args = sys.argv[1:]
    cmd = args[0] if args else "today"
    con = connect()

    if cmd == "ingest":
        ingest(con)
    elif cmd == "snapshot":
        sys.exit(snapshot(con))
    elif cmd in ("today", "day"):
        if cmd == "day" and len(args) > 1:
            date_str = args[1]
        else:
            date_str = datetime.now().astimezone().strftime("%Y-%m-%d")
        report_day(con, date_str)
    elif cmd == "week":
        end = datetime.now().astimezone()
        start = end - timedelta(days=6)
        report_range(con, start.strftime("%Y-%m-%d"), end.strftime("%Y-%m-%d"))
    elif cmd == "range":
        if len(args) < 3:
            print("uso: claude-metrics range YYYY-MM-DD YYYY-MM-DD", file=sys.stderr)
            sys.exit(1)
        report_range(con, args[1], args[2])
    elif cmd == "util":
        report_util(con, int(args[1]) if len(args) > 1 else 24)
    elif cmd == "models":
        report_models(con, int(args[1]) if len(args) > 1 else 30)
    elif cmd == "projects":
        report_projects(con, int(args[1]) if len(args) > 1 else 30)
    elif cmd == "months":
        report_months(con)
    elif cmd == "yield":
        compute_model_yield(con, window="five_hour", verbose=True)
        compute_model_yield(con, window="seven_day", verbose=True)
        export_json(con)
    elif cmd == "total":
        report_total(con)
    elif cmd == "waybar":
        waybar(con)
    elif cmd == "dashboard":
        dashboard(con, open_browser="--no-open" not in args)
    elif cmd == "export":
        print(export_json(con))
    elif cmd == "db":
        print(DB_PATH)
    else:
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
