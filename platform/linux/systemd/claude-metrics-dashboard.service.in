# Template — the installer (install.sh --astro) fills in @NODE@ and @DASHDIR@
# and writes the result to ~/.config/systemd/user/claude-metrics-dashboard.service.
# Only needed for the OPTIONAL Astro/Node dashboard. The Python CLI dashboard
# (`claude-metrics dashboard`) needs none of this.
[Unit]
Description=Local Claude Code metrics dashboard (Astro/Node)
After=network.target

[Service]
Type=simple
Environment=HOST=127.0.0.1
Environment=PORT=4319
Environment=NODE_ENV=production
WorkingDirectory=@DASHDIR@
ExecStart=@NODE@ @DASHDIR@/dist/server/entry.mjs
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
